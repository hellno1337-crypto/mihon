<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="${appName}"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true">

        <meta-data android:name="tachiyomi.extension"          android:value="true" />
        <meta-data android:name="tachiyomi.extension.class"    android:value="${extClass}" />
        <meta-data android:name="tachiyomi.extension.factory"  android:value="${extFactory}" />
        <meta-data android:name="tachiyomi.extension.nsfw"     android:value="${containsNsfw}" />
        <meta-data android:name="tachiyomi.extension.versionCode" android:value="${extVersionCode}" />

    </application>

</manifest>
